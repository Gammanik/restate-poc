@startuml loan-workflow-state-machine
title Loan Application Workflow - State Machine

skinparam state {
    BackgroundColor<<Approved>> LightGreen
    BackgroundColor<<Rejected>> LightCoral
    BackgroundColor<<Review>> LightYellow
    BackgroundColor<<Processing>> LightBlue
}

[*] --> SubmittedApplication : Submit Application

state SubmittedApplication {
    state "Loan Application Submitted" as submitted
    submitted : applicationId: String
    submitted : applicantName: String
    submitted : amount: BigDecimal
    submitted : income: BigDecimal
}

SubmittedApplication --> CreditCheck : Start Credit Check

state CreditCheck <<Processing>> {
    state "Checking Credit Score" as checking
    checking : Call CreditCheckService
    checking : Retry on failure (30% chance)
    checking : --
    checking : Returns: score (300-850)
    checking : Returns: reportId
}

CreditCheck --> DecisionMaking : Credit Check Complete\n[score determined]
CreditCheck --> CreditCheck : Retry on failure\n[simulated failure]

state DecisionMaking <<Processing>> {
    state "Making Decision" as deciding
    deciding : Evaluate credit score
    deciding : Apply business rules:
    deciding : • score >= 750 → APPROVED
    deciding : • 600 <= score < 680 → MANUAL_REVIEW
    deciding : • else → REJECTED
}

DecisionMaking --> ContractGeneration : Decision: APPROVED\n[score >= 750]
DecisionMaking --> ManualReview : Decision: MANUAL_REVIEW\n[600 <= score < 680]
DecisionMaking --> Rejected : Decision: REJECTED\n[score < 600 or 680 <= score < 750]

state ContractGeneration <<Processing>> {
    state "Generating Contract" as generating
    generating : Call ContractGenerationService
    generating : Create contract ID
    generating : Timestamp generation
}

ContractGeneration --> Approved : Contract Generated

state Approved <<Approved>> {
    state "Application Approved" as approved
    approved : decision: APPROVED
    approved : creditScore: Int
    approved : contractId: String
    approved : message: "Congratulations! Your loan\napplication has been approved."
}

state ManualReview <<Review>> {
    state "Pending Manual Review" as review
    review : decision: MANUAL_REVIEW
    review : creditScore: Int
    review : message: "Application pending manual\nreview. Please contact our team."
    review : --
    review : Note: In full implementation,
    review : would use durable promises
    review : and await signals
}

state Rejected <<Rejected>> {
    state "Application Rejected" as rejected
    rejected : decision: REJECTED
    rejected : creditScore: Int
    rejected : message: "We're sorry, your loan\napplication has been rejected."
}

Approved --> [*]
Rejected --> [*]
ManualReview --> [*]

note right of CreditCheck
  **Restate Features:**
  • Automatic retries on failure
  • Durable execution
  • State persistence
end note

note right of DecisionMaking
  **Decision Rules:**

  HIGH QUALITY (>= 750)
  → Automatic Approval

  BORDERLINE (600-679)
  → Manual Review Required

  LOW QUALITY (< 600 or 680-749)
  → Automatic Rejection
end note

note left of ManualReview
  **Future Enhancement:**
  Use Restate durable promises
  to await manual decision signal
end note

@enduml
